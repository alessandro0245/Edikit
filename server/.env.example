# Server Configuration
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/edikit?schema=public"

# JWT Configuration
JWT_SECRET=""
JWT_EXPIRES_IN=7d
JWT_TOKEN_NAME=user_token

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_CALLBACK_URL=http://localhost:8000/auth/apple/callback

# Stripe 
STRIPE_SECRET_KEY=""

# Nexrender 
NEXRENDER_CLOUD_API_KEY=""

# Claude API
CLAUDE_API_KEY=""
CLAUDE_MODEL=claude-haiku-4-5

# Render method: 'local' (for development) or 'lambda' (for production)
# Default: 'local'
AI_RENDER_METHOD=local

# Local Remotion dev server URL (used when AI_RENDER_METHOD=local)
REMOTION_DEV_URL=http://localhost:3001

# AWS 
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_OUTPUT_BUCKET=edikit-ai-videos-prod

# Remotion Lambda Configuration
REMOTION_LAMBDA_FUNCTION_NAME=""
REMOTION_SERVE_URL=""
REMOTION_S3_BUCKET=""

FREESOUND_API_KEY=""