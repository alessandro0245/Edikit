# Server Configuration
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/edikit?schema=public"

# JWT Configuration
JWT_SECRET=""
JWT_EXPIRES_IN=7d
JWT_TOKEN_NAME=user_token

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_CALLBACK_URL=http://localhost:8000/auth/apple/callback

# Stripe 
STRIPE_SECRET_KEY=""

# Nexrender (existing template rendering)
NEXRENDER_CLOUD_API_KEY=""

# === AI Video Generation ===

# Gemini API
GEMINI_API_KEY=""

# Render method: 'local' (for development) or 'lambda' (for production)
# Default: 'local'
AI_RENDER_METHOD=local

# Local Remotion dev server URL (used when AI_RENDER_METHOD=local)
REMOTION_DEV_URL=http://localhost:3000

# AWS Configuration (only required for Lambda rendering + S3)
# Leave empty to skip AWS integration

# AWS Region
AWS_REGION=us-east-1

# AWS Credentials
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# S3 Bucket for storing generated AI videos
S3_OUTPUT_BUCKET=edikit-ai-videos-prod

# Remotion Lambda Configuration (only for production)
REMOTION_LAMBDA_FUNCTION_NAME=""
REMOTION_SERVE_URL=""
REMOTION_S3_BUCKET=""